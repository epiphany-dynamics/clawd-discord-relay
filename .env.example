# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_OWNER_USER_ID=your_discord_user_id_here
# Optional: webhook URL for the #agent-feed channel (cron agents post here)
DISCORD_FEED_WEBHOOK_URL=

# ── Claude CLI ────────────────────────────────────────────────────────────────
CLAUDE_PATH=/root/.local/bin/claude
# Directory where your Claude project lives (CLAUDE.md, agents/, etc.)
PROJECT_DIR=/root/my-project
# Directory where agent .md profiles are stored (default: $PROJECT_DIR/agents)
AGENTS_DIR=/root/my-project/agents
# Claude spawn timeout in ms (default: 15 min)
CLAUDE_TIMEOUT_MS=900000

# ── Memory: Qdrant ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=claude-relay
# Optional: second brain collection (Gemini embeddings) — leave blank to skip
QDRANT_BRAIN_COLLECTION=

# ── Memory: Mem0 (optional — relay falls back to Qdrant+Ollama if down) ───────
MEM0_URL=http://localhost:8100

# ── Memory: Ollama (used for Qdrant embeddings when Mem0 is unavailable) ──────
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Memory: User ID ───────────────────────────────────────────────────────────
MEMORY_USER_ID=user

# ── Memory extraction (optional — requires OpenAI key) ────────────────────────
# Used to async-extract memorable facts from each conversation turn via GPT-4o-mini
OPENAI_API_KEY=

# ── Gemini (optional — for second-brain multimodal embeddings) ────────────────
GEMINI_API_KEY=

# ── Webhook server ────────────────────────────────────────────────────────────
WEBHOOK_PORT=3007
